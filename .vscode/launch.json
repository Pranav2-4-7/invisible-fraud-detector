{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run Backend (FastAPI)",
            "type": "python",
            "request": "launch",
            "program": "backend/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONUTF8": "1"
            }
        },
        {
            "name": "Python: Create Demo Model",
            "type": "python",
            "request": "launch",
            "program": "backend/scripts/create_demo_model.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/backend"
        }
    ]
}
